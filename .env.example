API_BASE_URL=http://127.0.0.1:8787
FMP_API_KEY=your_fmp_api_key
MARKETAUX_API_KEY=your_marketaux_api_key
NEWSAPI_KEY=your_newsapi_key
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key

# Optional server runtime overrides
HOST=0.0.0.0
PORT=8787

# RevenueCat public SDK key for subscriptions.
# Add your key to `.env` (do not commit secrets).
REVENUECAT_API_KEY=your_revenuecat_public_sdk_key

# RevenueCat entitlement identifier that represents premium access.
# Configure this in RevenueCat with the same identifier.
REVENUECAT_ENTITLEMENT_ID=premium
